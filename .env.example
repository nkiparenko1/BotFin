# === Frontend (Next.js) ===
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
NEXT_PUBLIC_API_URL=http://localhost:8000
# Server-side API URL for NextAuth (Docker: http://backend:8000)
INTERNAL_API_URL=

# Google OAuth (NextAuth provider → прокси к FastAPI)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === Backend (FastAPI) ===
DATABASE_URL=postgresql://botfin:botfin@postgres:5432/botfin
REDIS_URL=redis://redis:6379/0

JWT_SECRET=change-me-jwt-secret
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30

# Google OAuth (FastAPI side — обмен code на token)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# DeepSeek API
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_EMBEDDING_MODEL=deepseek-embedding

# CORS
CORS_ORIGINS=http://localhost:3000

# === Railway (production) ===
# Backend service:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
#   CORS_ORIGINS=https://${{Frontend.RAILWAY_PUBLIC_DOMAIN}}
#   ENV=production
# Frontend service (build arg + runtime):
#   NEXT_PUBLIC_API_URL=https://${{Backend.RAILWAY_PUBLIC_DOMAIN}}
#   INTERNAL_API_URL=http://${{Backend.RAILWAY_PRIVATE_DOMAIN}}:${{Backend.PORT}}
#   NEXTAUTH_URL=https://${{Frontend.RAILWAY_PUBLIC_DOMAIN}}
# Use Postgres + pgvector template (not plain Postgres): https://railway.com/deploy/postgres-with-pgvector-engine

POSTGRES_USER=botfin
POSTGRES_PASSWORD=botfin
POSTGRES_DB=botfin

# === S3 (optional, CSV storage) ===
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

# === App ===
ENV=development
